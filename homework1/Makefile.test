DEBUG=0

ifneq ($(DEBUG), 0)
CFLAGS=-O0 -g -G
else
CFLAGS=-O3 -lineinfo
endif

CFLAGS+=-Xcompiler=-Wall -maxrregcount=64 -arch=sm_75
CFLAGS+=`pkg-config opencv --cflags --libs`

# Reuse compiled objects from the main Makefile build.
# Run "make ex1" first, then "make -f Makefile.test test"

test.o: test.cu ex1.h
	nvcc --compile -dc $< $(CFLAGS) -o $@

test: ex1.o test.o ex1-cpu.o
	nvcc --link $(CFLAGS) -L. -lutils ex1.o test.o ex1-cpu.o -o $@

clean:
	rm -f test.o test

cleanall:
	$(MAKE) -f Makefile clean
	$(MAKE) -f Makefile.test clean
